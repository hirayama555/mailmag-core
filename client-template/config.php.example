<?php
declare(strict_types=1);

// ============================================================
// config.php - クライアント固有設定
// このファイルは config.php としてコピーし、各クライアントで編集する。
// 自動更新でも上書きされない。
// ============================================================

// サイトURL（末尾スラッシュ必須）
// 例: https://mail.example.com/mailmag/
define('SITE_URL', 'https://example.com/mailmag/');

// インストールディレクトリの絶対パス
define('BASE_DIR', realpath(__DIR__));

// データディレクトリ（既定: BASE_DIR/data）
define('DATA_DIR', BASE_DIR . '/data');

